# ============================================================
# LeadGen Francophone 360+ — Variables d'environnement
# Copier vers .env et remplir avant de lancer
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=leadgen
POSTGRES_PASSWORD=leadgen_secret
POSTGRES_DB=leadgen360
DATABASE_URL=postgresql://leadgen:leadgen_secret@localhost:5432/leadgen360

# --- API ---
API_SECRET_KEY=changeme_generate_a_real_secret_here

# --- LinkedIn (compte principal obligatoire) ---
LINKEDIN_EMAIL_1=your_linkedin_email@example.com
LINKEDIN_PASSWORD_1=your_linkedin_password

# LinkedIn compte 2 (optionnel, augmente la capacité à 500 req/jour)
LINKEDIN_EMAIL_2=
LINKEDIN_PASSWORD_2=

# LinkedIn compte 3 (optionnel)
LINKEDIN_EMAIL_3=
LINKEDIN_PASSWORD_3=

# --- LLM (Groq gratuit : https://console.groq.com) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-8b-8192

# --- Ollama (fallback local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# --- Enrichissement email (Hunter.io gratuit : 25 req/mois) ---
HUNTER_API_KEY=

# --- n8n ---
N8N_USER=admin
N8N_PASSWORD=admin123

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
